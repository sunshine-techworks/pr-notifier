{
  "name": "pr-notify",
  "version": "0.0.1",
  "private": true,
  "description": "Personal GitHub PR notifications for Slack",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:unit": "pnpm -r test:unit",
    "test:integration": "pnpm -r test:integration",
    "lint": "eslint 'packages/*/src/**/*.ts'",
    "lint:fix": "eslint 'packages/*/src/**/*.ts' --fix",
    "format": "dprint fmt",
    "format:check": "dprint check",
    "deploy": "cd packages/infra && cdk deploy",
    "synth": "cd packages/infra && cdk synth"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "dprint": "^0.45.0",
    "eslint": "^8.57.0",
    "eslint-plugin-import": "^2.29.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@9.0.0"
}
